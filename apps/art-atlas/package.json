{
  "name": "@illuvrse/art-atlas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "npm run validate:data && next build",
    "start": "next start -p 3002",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts",
    "verify": "npm run validate:data && npm run lint && npm run typecheck && npm run test",
    "lint": "next lint",
    "validate:data": "SKIP_REMOTE_URL_CHECK=1 node --import tsx scripts/validate-data.ts",
    "validate:data:strict": "node --import tsx scripts/validate-data.ts",
    "build:artist-cache": "node --import tsx scripts/build-artist-media-cache.ts"
  },
  "dependencies": {
    "next": "15.2.0",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.20.1",
    "eslint-config-next": "15.2.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
