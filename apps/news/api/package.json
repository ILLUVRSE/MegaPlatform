{
  "name": "@illuvrse/news-api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "bash -lc 'set -a; [ -f ../.env ] && . ../.env; set +a; ts-node src/server.ts'",
    "build": "tsc -p tsconfig.json",
    "start": "bash -lc 'set -a; [ -f ../.env ] && . ../.env; set +a; node dist/server.js'",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "bash -lc 'set -a; [ -f ../.env ] && . ../.env; set +a; prisma migrate dev --name init'",
    "prisma:seed": "bash -lc 'set -a; [ -f ../.env ] && . ../.env; set +a; ts-node prisma/seed.ts'"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "bullmq": "^5.40.4",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.5.0",
    "rss-parser": "^3.13.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "prisma": "^6.4.1"
  }
}
