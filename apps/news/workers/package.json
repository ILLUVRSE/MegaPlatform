{
  "name": "@illuvrse/news-workers",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "bash -lc 'set -a; [ -f ../.env ] && . ../.env; set +a; ts-node src/index.ts'",
