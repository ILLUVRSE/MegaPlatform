{
  "name": "@illuvrse/pixelbrawl",
  "version": "1.0.0",
  "description": "Mobile-first HTML5 1v1 2.5D pixel fighter inspired by Tekken lane sidesteps.",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "check:assets": "node scripts/check-roster-assets.mjs && node scripts/check-fighter-assets.mjs",
    "sync:assets": "node scripts/sync-assets-to-public.mjs",
    "dev": "npm run sync:assets && npm run check:assets && vite --port 5174",
    "build": "npm run sync:assets && npm run check:assets && vite build",
    "preview": "vite preview",
    "check": "node --check src/main.js",
    "gen:sprites": "node scripts/generate-fighter-atlases.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "vite": "^7.1.3",
    "vitest": "^3.2.0"
  }
}
