// Prisma schema for ILLUVRSE Admin Dashboard
// Datasource and generator are intentionally simple for local development.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String                   @id @default(cuid())
  email              String                   @unique
  name               String?
  role               String                   @default("user")
  disabled           Boolean                  @default(false)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  accounts           Account[]
  sessions           Session[]
  adminAudits        AdminAudit[]             @relation("AdminActor")
  studioProjects     StudioProject[]
  shortPosts         ShortPost[]
  profiles           Profile[]
  userGames          UserGame[]
  contentItems       ContentItem[]            @relation("ContentCreator")
  contentTransitions ContentStateTransition[] @relation("ContentTransitionActor")
  creatorProfile     CreatorProfile?
  showProjects       ShowProject[]
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  permissions Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Show {
  id                String     @id @default(cuid())
  title             String
  slug              String     @unique
  description       String?
  posterUrl         String?
  heroUrl           String?
  featured          Boolean    @default(false)
  trending          Boolean    @default(false)
  newRelease        Boolean    @default(false)
  heroPriority      Int?
  featuredRail      String?
  featuredRailOrder Int?
  watchOrder        Int?
  maturityRating    String?
  isPremium         Boolean    @default(false)
  price             Int?
  genres            String[]   @default([])
  tags              String[]   @default([])
  cast              String[]   @default([])
  seasons           Season[]
  feedPosts         FeedPost[]
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
}

model Season {
  id        String    @id @default(cuid())
  showId    String
  number    Int
  title     String
  show      Show      @relation(fields: [showId], references: [id])
  episodes  Episode[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Episode {
  id            String          @id @default(cuid())
  seasonId      String
  title         String
  description   String?
  lengthSeconds Int
  assetUrl      String
  season        Season          @relation(fields: [seasonId], references: [id])
  playlistItems PlaylistItem[]
  livePrograms  LiveProgram[]
  watchProgress WatchProgress[]
  feedPosts     FeedPost[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Party {
  id            String         @id @default(cuid())
  code          String         @unique
  name          String
  isPublic      Boolean        @default(true)
  hostId        String
  currentIndex  Int            @default(0)
  playbackState String         @default("idle")
  seats         Seat[]
  playlist      PlaylistItem[]
  participants  Participant[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Seat {
  id         String   @id @default(cuid())
  partyId    String
  seatIndex  Int
  locked     Boolean  @default(false)
  occupantId String?
  party      Party    @relation(fields: [partyId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([partyId, seatIndex])
}

model PlaylistItem {
  id        String   @id @default(cuid())
  partyId   String
  episodeId String?
  assetUrl  String
  order     Int
  party     Party    @relation(fields: [partyId], references: [id])
  episode   Episode? @relation(fields: [episodeId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum StudioProjectType {
  SHORT
  MEME
  REMIX
  SHOW
  GAME
  PARTY_GAME
}

enum StudioProjectStatus {
  DRAFT
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  PUBLISHED
}

enum ShowProjectFormat {
  SERIES
  MOVIE
}

enum ShowProjectStatus {
  DRAFT
  IN_PRODUCTION
  READY_TO_PUBLISH
  PUBLISHED
}

enum ShowEpisodeStatus {
  DRAFT
  READY
  PUBLISHED
}

enum ShowEpisodeTemplateType {
  STANDARD_EPISODE
  COLD_OPEN_EPISODE
  MOVIE_CHAPTER
}

enum AgentJobType {
  SHORT_SCRIPT
  SHORT_SCENES
  SHORT_RENDER
  MEME_CAPTIONS
  MEME_RENDER
  VIDEO_CLIP_EXTRACT
  VIDEO_TRANSCODE
  THUMBNAIL_GENERATE
}

enum AgentJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum StudioAssetKind {
  SHORT_MP4
  MEME_PNG
  IMAGE_UPLOAD
  AUDIO_UPLOAD
  VIDEO_UPLOAD
  THUMBNAIL
  TEXT
  HLS_MANIFEST
}

enum StudioTemplateKind {
  SHORT
  MEME
  GAME
}

enum AssetOriginType {
  UPLOAD
  GENERATED
  REMIX
  TEMPLATE
  IMPORTED
}

enum AssetRightsStatus {
  UNVERIFIED
  LICENSED
  OWNED
  RESTRICTED
}

enum ContentQaStatus {
  PASS
  FAIL
}

enum RemixJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  BLOCKED
}

enum DistributionActionStatus {
  SCHEDULED
  EXECUTED
  SKIPPED
  FAILED
}

enum PlatformNotificationStatus {
  UNREAD
  READ
  ARCHIVED
  ACTED
}

enum SquadInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  REVOKED
}

enum EntitlementStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum ShortMediaType {
  VIDEO
  IMAGE
}

enum FeedPostType {
  SHORT
  MEME
  WATCH_EPISODE
  WATCH_SHOW
  LIVE_CHANNEL
  GAME
  LINK
  UPLOAD
  TEXT
  SHARE
}

enum ContentState {
  DRAFT
  PROCESSING
  REVIEW
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum ContentAssetKind {
  VIDEO
  THUMBNAIL
  AUDIO
}

enum UserGameStatus {
  DRAFT
  PUBLISHED
}

model UserGame {
  id           String            @id @default(cuid())
  ownerId      String?
  ownerKey     String?
  title        String
  description  String?
  status       UserGameStatus    @default(DRAFT)
  version      Int               @default(1)
  seed         String
  templateId   String
  specJson     Json
  thumbnailUrl String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  publishedAt  DateTime?
  owner        User?             @relation(fields: [ownerId], references: [id])
  versions     UserGameVersion[]

  @@index([ownerId])
  @@index([ownerKey])
  @@index([status, publishedAt])
}

model UserGameVersion {
  id         String   @id @default(cuid())
  userGameId String
  version    Int
  specJson   Json
  createdAt  DateTime @default(now())
  userGame   UserGame @relation(fields: [userGameId], references: [id])

  @@index([userGameId, version])
}

model StudioProject {
  id               String              @id @default(cuid())
  type             StudioProjectType
  title            String
  description      String?
  status           StudioProjectStatus @default(DRAFT)
  createdById      String?
  creatorProfileId String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  jobs             AgentJob[]
  assets           StudioAsset[]
  posts            ShortPost[]
  createdBy        User?               @relation(fields: [createdById], references: [id])
  creatorProfile   CreatorProfile?     @relation(fields: [creatorProfileId], references: [id])
  qaResults        ContentQaResult[]
  remixJobs        RemixJob[]
  assetLineages    AssetLineage[]
}

model ShowProject {
  id             String            @id @default(cuid())
  slug           String            @unique
  title          String
  description    String?
  format         ShowProjectFormat
  status         ShowProjectStatus @default(DRAFT)
  ownerId        String
  posterImageUrl String?
  bannerImageUrl String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  owner          User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  episodes       ShowEpisode[]

  @@index([ownerId, createdAt])
  @@index([status, updatedAt])
}

model ShowEpisode {
  id             String                  @id @default(cuid())
  showProjectId  String
  seasonNumber   Int?
  episodeNumber  Int?
  title          String
  slug           String
  synopsis       String?
  runtimeSeconds Int?
  status         ShowEpisodeStatus       @default(DRAFT)
  templateType   ShowEpisodeTemplateType
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  showProject    ShowProject             @relation(fields: [showProjectId], references: [id], onDelete: Cascade)
  scenes         ShowScene[]
  shortDrafts    DerivedShortDraft[]

  @@unique([showProjectId, slug])
  @@index([showProjectId, createdAt])
  @@index([showProjectId, status, updatedAt])
}

model ShowScene {
  id                 String      @id @default(cuid())
  showEpisodeId      String
  sceneNumber        Int
  title              String
  scriptText         String
  startIntentSeconds Int?
  endIntentSeconds   Int?
  tags               Json?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  showEpisode        ShowEpisode @relation(fields: [showEpisodeId], references: [id], onDelete: Cascade)
  shortDrafts        DerivedShortDraft[]

  @@unique([showEpisodeId, sceneNumber])
  @@index([showEpisodeId, createdAt])
  @@index([showEpisodeId, updatedAt])
}

model DerivedShortDraft {
  id               String      @id @default(cuid())
  showEpisodeId    String
  showSceneId      String
  title            String
  clipStartSeconds Int
  clipEndSeconds   Int
  notes            String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  showEpisode      ShowEpisode @relation(fields: [showEpisodeId], references: [id], onDelete: Cascade)
  showScene        ShowScene   @relation(fields: [showSceneId], references: [id], onDelete: Cascade)

  @@unique([showEpisodeId, showSceneId])
  @@index([showEpisodeId, createdAt])
  @@index([showSceneId])
}

model CreatorProfile {
  id                  String                 @id @default(cuid())
  userId              String                 @unique
  handle              String                 @unique
  displayName         String
  reputationScore     Int                    @default(0)
  level               Int                    @default(1)
  badges              String[]               @default([])
  metadataJson        Json?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  user                User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects            StudioProject[]
  templates           StudioTemplate[]
  revenueAttributions RevenueAttribution[]
  progression         CreatorProgression?
  progressionEvents   CreatorProgressEvent[]
}

model StudioTemplate {
  id               String                  @id @default(cuid())
  creatorProfileId String
  title            String
  description      String?
  kind             StudioTemplateKind
  isPublished      Boolean                 @default(false)
  latestVersion    Int                     @default(1)
  tags             String[]                @default([])
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  creatorProfile   CreatorProfile          @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  versions         StudioTemplateVersion[]

  @@index([creatorProfileId, createdAt])
  @@index([kind, isPublished, createdAt])
}

model StudioTemplateVersion {
  id          String         @id @default(cuid())
  templateId  String
  version     Int
  title       String
  description String?
  schemaJson  Json
  createdAt   DateTime       @default(now())
  template    StudioTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, version])
  @@index([templateId, createdAt])
}

model ContentItem {
  id          String                   @id @default(cuid())
  type        String
  title       String
  description String?
  state       ContentState             @default(DRAFT)
  creatorId   String?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  creator     User?                    @relation("ContentCreator", fields: [creatorId], references: [id])
  assets      ContentAsset[]
  transitions ContentStateTransition[]

  @@index([state, createdAt])
  @@index([creatorId, createdAt])
}

model ContentAsset {
  id         String           @id @default(cuid())
  contentId  String
  kind       ContentAssetKind
  storageKey String?
  url        String
  metadata   Json?
  createdAt  DateTime         @default(now())
  content    ContentItem      @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId, createdAt])
}

model ContentStateTransition {
  id        String       @id @default(cuid())
  contentId String
  fromState ContentState
  toState   ContentState
  actorId   String?
  reason    String?
  createdAt DateTime     @default(now())
  content   ContentItem  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  actor     User?        @relation("ContentTransitionActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([contentId, createdAt])
  @@index([actorId, createdAt])
}

model AgentJob {
  id         String         @id @default(cuid())
  projectId  String
  type       AgentJobType
  status     AgentJobStatus @default(QUEUED)
  inputJson  Json
  outputJson Json?
  error      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  project    StudioProject  @relation(fields: [projectId], references: [id])
}

model StudioAsset {
  id            String          @id @default(uuid())
  projectId     String
  uploadId      String          @unique @default(uuid())
  jobId         String?
  s3Key         String?
  checksum      String?
  size          Int?
  status        String          @default("pending")
  costEstimate  Decimal?        @db.Decimal(12, 6)
  ttlAt         DateTime?
  kind          StudioAssetKind
  url           String
  storageKey    String?
  contentType   String?
  sizeBytes     Int?
  temporary     Boolean         @default(false)
  isSafe        Boolean         @default(false)
  isFlagged     Boolean         @default(false)
  isQuarantined Boolean         @default(false)
  metaJson      Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  finalizedAt   DateTime?
  project       StudioProject   @relation(fields: [projectId], references: [id])
  lineage       AssetLineage?

  @@index([kind, createdAt])
  @@index([projectId, status])
  @@index([temporary, createdAt])
}

model AssetLineage {
  id             String            @id @default(cuid())
  projectId      String
  studioAssetId  String            @unique
  rootAssetId    String?
  parentAssetId  String?
  originType     AssetOriginType
  rightsStatus   AssetRightsStatus @default(UNVERIFIED)
  provenanceJson Json?
  createdAt      DateTime          @default(now())
  project        StudioProject     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  studioAsset    StudioAsset       @relation(fields: [studioAssetId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}

model ContentQaResult {
  id             String          @id @default(cuid())
  projectId      String
  status         ContentQaStatus
  technicalScore Int
  policyScore    Int
  issuesJson     Json?
  checkedBy      String          @default("qa-agent-v1")
  createdAt      DateTime        @default(now())
  project        StudioProject   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}

model RevenueAttribution {
  id               String         @id @default(cuid())
  creatorProfileId String
  shortPostId      String?
  projectId        String?
  actionType       String
  eventSource      String
  revenueCents     Int            @default(0)
  occurredAt       DateTime       @default(now())
  metadataJson     Json?
  creatorProfile   CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)

  @@index([creatorProfileId, occurredAt])
  @@index([actionType, occurredAt])
}

model CreatorProgression {
  id               String         @id @default(cuid())
  creatorProfileId String         @unique
  level            Int            @default(1)
  xp               Int            @default(0)
  tier             String         @default("RISING")
  rewardsEarned    Int            @default(0)
  updatedAt        DateTime       @updatedAt
  createdAt        DateTime       @default(now())
  creatorProfile   CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
}

model CreatorProgressEvent {
  id               String         @id @default(cuid())
  creatorProfileId String
  source           String
  points           Int
  metadataJson     Json?
  createdAt        DateTime       @default(now())
  creatorProfile   CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)

  @@index([creatorProfileId, createdAt])
}

model RemixJob {
  id            String         @id @default(cuid())
  projectId     String
  sourceAssetId String
  requestedById String
  status        RemixJobStatus @default(QUEUED)
  blockedReason String?
  prompt        String?
  metadataJson  Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  project       StudioProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([status, createdAt])
}

model DistributionAction {
  id           String                   @id @default(cuid())
  module       String
  targetType   String
  targetId     String
  actionType   String
  priority     Int                      @default(0)
  status       DistributionActionStatus @default(SCHEDULED)
  scheduledFor DateTime
  createdById  String?
  metadataJson Json?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  @@index([status, scheduledFor])
  @@index([module, createdAt])
}

model ShortPost {
  id          String          @id @default(cuid())
  projectId   String?         @unique
  title       String
  caption     String
  mediaUrl    String
  mediaType   ShortMediaType
  isPremium   Boolean         @default(false)
  price       Int?
  createdById String?
  createdAt   DateTime        @default(now())
  publishedAt DateTime        @default(now())
  project     StudioProject?  @relation(fields: [projectId], references: [id])
  createdBy   User?           @relation(fields: [createdById], references: [id])
  purchases   ShortPurchase[]
  feedPosts   FeedPost[]

  @@index([createdById, publishedAt])
  @@index([mediaType, publishedAt])
}

model ShortPurchase {
  id          String    @id @default(cuid())
  shortPostId String
  buyerId     String?
  buyerAnonId String?
  createdAt   DateTime  @default(now())
  shortPost   ShortPost @relation(fields: [shortPostId], references: [id])

  @@index([shortPostId])
  @@index([buyerId])
  @@index([buyerAnonId])
}

model Profile {
  id        String          @id @default(cuid())
  userId    String
  name      String
  avatarUrl String?
  isKids    Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  listItems MyListItem[]
  progress  WatchProgress[]
}

model MyListItem {
  id        String   @id @default(cuid())
  profileId String
  mediaType String
  showId    String?
  createdAt DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, mediaType, showId])
  @@index([profileId])
}

model WatchProgress {
  id          String   @id @default(cuid())
  profileId   String
  episodeId   String
  positionSec Int      @default(0)
  durationSec Int      @default(0)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([profileId, episodeId])
  @@index([profileId, updatedAt])
}

model LiveChannel {
  id                        String        @id @default(cuid())
  slug                      String        @unique
  name                      String
  description               String?
  logoUrl                   String?
  heroUrl                   String?
  category                  String?
  streamUrl                 String?
  isVirtual                 Boolean       @default(false)
  defaultProgramDurationMin Int?
  scheduleLocked            Boolean       @default(false)
  lastCheckedAt             DateTime?
  lastHealthyAt             DateTime?
  lastError                 String?
  isActive                  Boolean       @default(true)
  programs                  LiveProgram[]
  feedPosts                 FeedPost[]
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt
}

model LiveProgram {
  id          String      @id @default(cuid())
  channelId   String
  title       String
  description String?
  startsAt    DateTime
  endsAt      DateTime
  episodeId   String?
  streamUrl   String?
  order       Int?
  channel     LiveChannel @relation(fields: [channelId], references: [id])
  episode     Episode?    @relation(fields: [episodeId], references: [id])

  @@index([channelId, startsAt])
}

model FeedPost {
  id             String         @id @default(cuid())
  type           FeedPostType
  authorId       String?
  authorProfile  String?
  caption        String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  shortPostId    String?
  showId         String?
  episodeId      String?
  liveChannelId  String?
  gameKey        String?
  linkUrl        String?
  uploadUrl      String?
  shareOfId      String?
  isHidden       Boolean        @default(false)
  isShadowbanned Boolean        @default(false)
  isPinned       Boolean        @default(false)
  isFeatured     Boolean        @default(false)
  featuredRank   Int            @default(0)
  likeCount      Int            @default(0)
  commentCount   Int            @default(0)
  shareCount     Int            @default(0)
  shareOf        FeedPost?      @relation("FeedShare", fields: [shareOfId], references: [id])
  shares         FeedPost[]     @relation("FeedShare")
  reactions      FeedReaction[]
  comments       FeedComment[]
  reports        FeedReport[]
  shortPost      ShortPost?     @relation(fields: [shortPostId], references: [id])
  show           Show?          @relation(fields: [showId], references: [id])
  episode        Episode?       @relation(fields: [episodeId], references: [id])
  liveChannel    LiveChannel?   @relation(fields: [liveChannelId], references: [id])

  @@index([createdAt])
  @@index([isPinned, featuredRank])
  @@index([type, createdAt])
}

model FeedReaction {
  id        String   @id @default(cuid())
  postId    String
  userId    String?
  anonId    String?
  type      String
  createdAt DateTime @default(now())
  post      FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, anonId, type])
  @@index([postId])
}

model FeedComment {
  id        String   @id @default(cuid())
  postId    String
  userId    String?
  anonId    String?
  body      String
  createdAt DateTime @default(now())
  post      FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
}

model FeedReport {
  id         String    @id @default(cuid())
  postId     String
  reporterId String?
  anonId     String?
  reason     String
  details    String?
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
  post       FeedPost  @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([postId, resolvedAt])
  @@index([reporterId, createdAt])
  @@index([resolvedAt, createdAt])
}

model SchedulerRun {
  id              String    @id @default(cuid())
  scope           String    @default("LIVE")
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  status          String    @default("RUNNING")
  programsCreated Int       @default(0)
  channelsTouched Int       @default(0)
  errors          Int       @default(0)
  summary         String?
  triggeredById   String?
}

model Participant {
  id          String   @id @default(cuid())
  partyId     String
  userId      String
  displayName String?
  joinedAt    DateTime @default(now())
  party       Party    @relation(fields: [partyId], references: [id])

  @@unique([partyId, userId])
  @@index([partyId, joinedAt])
  @@index([userId, joinedAt])
}

model AdminAudit {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  details   String
  createdAt DateTime @default(now())
  admin     User     @relation("AdminActor", fields: [adminId], references: [id])

  @@index([adminId, createdAt])
  @@index([action, createdAt])
}

model PlatformEvent {
  id        String   @id @default(cuid())
  event     String
  module    String
  href      String
  surface   String
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([event, createdAt])
  @@index([module, createdAt])
  @@index([surface, createdAt])
}

model PlatformSessionGraph {
  id               String   @id @default(cuid())
  sessionKey       String   @unique
  userId           String?
  anonId           String?
  profileId        String?
  creatorProfileId String?
  currentModule    String
  sourceModule     String?
