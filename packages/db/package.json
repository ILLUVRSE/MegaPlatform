{
  "name": "@illuvrse/db",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "prisma:generate": "prisma generate --schema schema.prisma",
    "prisma:validate": "prisma validate --schema schema.prisma",
    "prisma:migrate:status": "prisma migrate status --schema schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema schema.prisma",
    "prisma:seed": "prisma db seed --schema schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "prisma": {
    "seed": "node --import tsx seed.ts",
    "schema": "schema.prisma"
  }
}
