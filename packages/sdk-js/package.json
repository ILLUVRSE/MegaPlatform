{
  "name": "@illuvrse/sdk-js",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "pnpm run clean && tsc -p tsconfig.build.esm.json && tsc -p tsconfig.build.cjs.json && tsc -p tsconfig.build.types.json && node ./scripts/write-cjs-package-json.mjs",
    "clean": "node ./scripts/clean.mjs",
    "test": "vitest run --config vitest.config.ts"
  },
  "peerDependencies": {
    "react": "^18.3.1 || ^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
